# Gmail SMTP Configuration
# Get app password from: https://myaccount.google.com/ > Security > App passwords
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-16-char-app-password-here

# Email recipient for notifications
RECIPIENT_EMAIL=recipient@example.com

# Case Information
CASE_NUMBER=46C01-2511-ES-000237
CASE_URL=https://mycase.in.gov/cases/

# Check interval in hours (default: 6)
CHECK_INTERVAL=6
